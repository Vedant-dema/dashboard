# Copy to `backend/.env` or set in your host (Render, Railway, etc.).
#
# Local file: `backend/.env` is loaded automatically when the app imports `app.core.config`
# (via python-dotenv). Environment variables already set in your shell take precedence.

# --- Runtime profile ---
# APP_ENV controls strict startup checks and production guardrails.
# APP_ENV=development
# APP_DEBUG=0
# STARTUP_CHECKS_STRICT=0
# LOG_LEVEL=INFO

# --- CORS (browser -> API from another origin, e.g. Vercel SPA -> Render API) ---
# Comma-separated exact origins (scheme + host + port). Defaults include Vite dev only.
# CORS_ORIGINS=https://your-app.vercel.app,http://localhost:5173
#
# Preview deployments: each Vercel preview URL is a different origin. Use a regex
# (matched in addition to CORS_ORIGINS):
# CORS_ORIGIN_REGEX=https://.*\.vercel\.app
#
# allow_credentials=True is enabled; do not use "*" for origins in production.

# --- Geocoding (address autocomplete: GET /api/v1/geocode/search) ---
# osm (default): Photon + OpenStreetMap Nominatim, no key.
# mapbox: set MAPBOX_ACCESS_TOKEN (Mapbox account tokens).
# google: set GOOGLE_MAPS_API_KEY with Geocoding API enabled in Google Cloud Console.
GEOCODING_PROVIDER=osm

# MAPBOX_ACCESS_TOKEN=
# GOOGLE_MAPS_API_KEY=

# Optional aliases / tuning
# GOOGLE_GEOCODING_API_KEY=
# GEOCODE_DISABLE_PHOTON=0
# PHOTON_API_BASE=https://photon.komoot.io
# NOMINATIM_API_BASE=https://nominatim.openstreetmap.org
# NOMINATIM_USER_AGENT=YourApp/1.0 (contact@yourdomain.example)

# --- Optional: AI Latin/English name spelling variants (customer modal) ---
# Uses OpenAI-compatible POST .../v1/chat/completions. If unset, the UI hides the feature.
# NAME_VARIANTS_API_KEY=
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# NAME_VARIANTS_MODEL=gpt-4o-mini

# --- Optional: live UI translation (batch EN -> target; used when VITE_ENABLE_LIVE_UI_TRANSLATION=true) ---
# Google Cloud Translation API v2 (enable "Cloud Translation API" in the same project as the key).
# GOOGLE_TRANSLATE_API_KEY=
# Or self-hosted / public LibreTranslate (set URL; optional API key if your instance requires it).
# LIBRETRANSLATE_URL=https://libretranslate.com
# LIBRETRANSLATE_API_KEY=

# --- Customer persistence mode ---
# demo_blob (default): transitional SQLite demo store
# db/postgres/postgresql: SQLAlchemy/Alembic-managed SQL persistence for customer domain
# CUSTOMERS_STORE_MODE=demo_blob

# SQLAlchemy database URL
# Example:
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/dema
# Render-style postgres://... and plain postgresql://... are normalized automatically
# to postgresql+psycopg://... at runtime.
# Optional SQL echo:
# DATABASE_ECHO=0

# --- Object storage (Phase 6 foundation) ---
# local: local filesystem fallback for dev/test
# azure_blob: Azure Blob Storage production target
# STORAGE_PROVIDER=local
# STORAGE_LOCAL_ROOT=./storage
# STORAGE_DEFAULT_DOWNLOAD_TTL_SECONDS=900
#
# Logical container names (used by local provider and as defaults)
# STORAGE_CONTAINER_RAW=customer-raw
# STORAGE_CONTAINER_DERIVED=customer-derived
#
# Azure Blob provider configuration
# AZURE_BLOB_ACCOUNT_URL=https://<account>.blob.core.windows.net
# AZURE_BLOB_CONNECTION_STRING=
# AZURE_BLOB_CONTAINER_RAW=customer-raw
# AZURE_BLOB_CONTAINER_DERIVED=customer-derived
# AZURE_BLOB_SAS_UPLOAD_ENABLED=0

# --- VAT/VIES runtime safety (avoid proxy/gateway timeouts) ---
# Target wall-clock budget for the VAT check (core VIES + enrich + mapping).
# The API enforces a hard asyncio deadline of (this value + 1.5s) and returns 504 JSON if exceeded,
# so clients see structured errors instead of empty gateway bodies.
# Keep below your hosting proxy timeout (Render/others).
# VIES_CHECK_ENDPOINT_MAX_TOTAL_SEC=9
# Hard cap for one core VIES retry loop; should stay <= endpoint cap above.
# VIES_MAX_TOTAL_SEC=9

# Optional: disable expensive SOAP/member-state enrichment fallback when needed.
# VIES_ENRICH_FALLBACK_ENABLED=1
