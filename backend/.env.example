# Copy to `.env` or set in your host (Render, Railway, …). Values are read by `main.py` via os.environ.

# --- Geocoding (address autocomplete: GET /api/v1/geocode/search) ---
# osm (default): Photon + OpenStreetMap Nominatim — no key.
# mapbox: set MAPBOX_ACCESS_TOKEN (Mapbox account → tokens).
# google: set GOOGLE_MAPS_API_KEY with Geocoding API enabled in Google Cloud Console.
GEOCODING_PROVIDER=osm

# MAPBOX_ACCESS_TOKEN=
# GOOGLE_MAPS_API_KEY=

# Optional aliases / tuning
# GOOGLE_GEOCODING_API_KEY=
# GEOCODE_DISABLE_PHOTON=0
# PHOTON_API_BASE=https://photon.komoot.io
# NOMINATIM_API_BASE=https://nominatim.openstreetmap.org
# NOMINATIM_USER_AGENT=YourApp/1.0 (contact@yourdomain.example)
