Project DEMA_Customer_360 {
  database_type: "PostgreSQL"
  Note: "Recommended DEMA-ready Customer 360 schema for dbdiagram.io"
}

Enum customer_type {
  company
  person
}

Enum customer_status {
  active
  inactive
  blocked
}

Enum address_type {
  primary
  billing
  shipping
  branch
  service
  other
}

Enum task_status {
  pending
  in_progress
  done
  cancelled
}

Enum appointment_status {
  planned
  completed
  cancelled
  missed
}

Enum interaction_type {
  call
  email
  meeting
  note
  whatsapp
  other
}

Enum relationship_type {
  parent
  subsidiary
  branch
  billing_contact
  service_contact
  partner
  competitor
  other
}

Enum lifecycle_stage {
  lead
  qualified
  active
  inactive
  vip
  lost
}

Enum channel_type {
  email
  phone
  sms
  whatsapp
  mixed
  none
}

Enum campaign_status {
  draft
  active
  paused
  completed
  archived
}

Enum campaign_event_type {
  added
  sent
  opened
  clicked
  replied
  converted
  unsubscribed
}

Enum insight_type {
  risk
  opportunity
  alert
  recommendation
}

Enum severity_level {
  low
  medium
  high
  critical
}

Enum insight_status {
  open
  in_review
  resolved
  dismissed
}

Enum action_type {
  email
  task
  offer
  reminder
  call
}

Enum action_status {
  pending
  approved
  executed
  cancelled
  failed
}

Enum activity_entity_type {
  customer
  task
  campaign
  document
  appointment
  interaction
  insight
  action
}

Enum activity_action_type {
  created
  updated
  deleted
  completed
  linked
  unlinked
  sent
  generated
  resolved
}

Table staff_users {
  id bigint [pk, increment]
  full_name varchar(120) [not null]
  email varchar(255) [not null, unique]
  role varchar(80)
  department varchar(80)
  is_active boolean [not null, default: true]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
}

Table customers {
  id bigint [pk, increment]
  kunden_nr varchar(32) [not null, unique]
  customer_type customer_type [not null]
  name varchar(255) [not null]
  legal_form varchar(80)
  industry varchar(120)
  is_vehicle_dealer boolean [not null, default: false]
  status customer_status [not null, default: 'active']
  source varchar(120)
  assigned_to bigint [ref: > staff_users.id]
  notes text
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  Indexes {
    kunden_nr
    status
    assigned_to
    name
  }
}

Table customer_details {
  id bigint [pk, increment]
  customer_id bigint [not null, unique, ref: > customers.id]
  company_prefix varchar(120)
  first_name varchar(120)
  last_name varchar(120)
  notes text
}

Table addresses {
  id bigint [pk, increment]
  customer_id bigint [not null, ref: > customers.id]
  type address_type [not null, default: 'primary']
  street varchar(255)
  postal_code varchar(20)
  city varchar(120)
  country_code char(2)
  created_at timestamptz [not null, default: `now()`]

  Indexes {
    customer_id
    type
    city
    postal_code
  }
}

Table contacts {
  id bigint [pk, increment]
  customer_id bigint [not null, ref: > customers.id]
  contact_person varchar(120) [not null]
  role varchar(120)
  phone varchar(40)
  fax varchar(40)
  email varchar(255)
  website varchar(255)
  notes text
  created_at timestamptz [not null, default: `now()`]

  Indexes {
    customer_id
    email
  }
}

Table customer_financials {
  id bigint [pk, increment]
  customer_id bigint [not null, unique, ref: > customers.id]
  account_number varchar(40)
  credit_limit numeric(12,2)
  billing_name varchar(255)
  billing_street varchar(255)
  billing_postal_code varchar(20)
  billing_city varchar(120)
  is_blocked boolean [not null, default: false]
  bank_name varchar(120)
  bic varchar(20)
  iban varchar(34)
  direct_debit_enabled boolean [not null, default: false]
  notes text
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
}

Table customer_roles {
  id bigint [pk, increment]
  customer_id bigint [not null, ref: > customers.id]
  role varchar(80) [not null]
  valid_from date
  valid_to date

  Indexes {
    customer_id
    role
  }
}

Table documents {
  id bigint [pk, increment]
  customer_id bigint [not null, ref: > customers.id]
  name varchar(255) [not null]
  size bigint
  mime_type varchar(120)
  file_url text [not null]
  created_at timestamptz [not null, default: `now()`]

  Indexes {
    customer_id
  }
}

Table appointments {
  id bigint [pk, increment]
  customer_id bigint [not null, ref: > customers.id]
  date date [not null]
  time varchar(10)
  purpose varchar(255) [not null]
  status appointment_status [not null, default: 'planned']
  created_by bigint [ref: > staff_users.id]
  created_at timestamptz [not null, default: `now()`]

  Indexes {
    customer_id
    date
    status
  }
}

Table customer_relationships {
  id bigint [pk, increment]
  customer_id bigint [not null, ref: > customers.id]
  related_customer_id bigint [not null, ref: > customers.id]
  relation_type relationship_type [not null]
  created_at timestamptz [not null, default: `now()`]

  Indexes {
    customer_id
    related_customer_id
    relation_type
  }
}

Table risk_profiles {
  id bigint [pk, increment]
  customer_id bigint [not null, unique, ref: > customers.id]
  general_doc boolean [not null, default: false]
  register_extract date
  business_verification date
  id_copy_valid_until date
  processor bigint [ref: > staff_users.id]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
}

Table change_logs {
  id bigint [pk, increment]
  customer_id bigint [not null, ref: > customers.id]
  action varchar(40) [not null]
  changed_by bigint [ref: > staff_users.id]
  changes_json jsonb
  timestamp timestamptz [not null, default: `now()`]

  Indexes {
    customer_id
    timestamp
  }
}

Table interactions {
  id bigint [pk, increment]
  customer_id bigint [not null, ref: > customers.id]
  type interaction_type [not null]
  notes text
  created_by bigint [ref: > staff_users.id]
  created_at timestamptz [not null, default: `now()`]

  Indexes {
    customer_id
    type
    created_at
  }
}

Table tasks {
  id bigint [pk, increment]
  customer_id bigint [not null, ref: > customers.id]
  assigned_to bigint [ref: > staff_users.id]
  title varchar(255) [not null]
  status task_status [not null, default: 'pending']
  due_date date
  created_by bigint [ref: > staff_users.id]
  created_at timestamptz [not null, default: `now()`]

  Indexes {
    customer_id
    assigned_to
    status
    due_date
  }
}

Table customer_marketing_profiles {
  id bigint [pk, increment]
  customer_id bigint [not null, unique, ref: > customers.id]
  lifecycle_stage lifecycle_stage [not null, default: 'lead']
  campaign_source varchar(120)
  acquisition_date date
  preferred_channel channel_type [not null, default: 'none']
  segment varchar(120)
  score int
  consent_email boolean [not null, default: false]
  consent_sms boolean [not null, default: false]
  consent_phone boolean [not null, default: false]
  notes text
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  Indexes {
    customer_id
    lifecycle_stage
    segment
  }
}

Table customer_tags {
  id bigint [pk, increment]
  name varchar(80) [not null, unique]
}

Table customer_tag_links {
  customer_id bigint [not null, ref: > customers.id]
  tag_id bigint [not null, ref: > customer_tags.id]

  Indexes {
    (customer_id, tag_id) [pk]
  }
}

Table campaigns {
  id bigint [pk, increment]
  name varchar(255) [not null]
  channel channel_type [not null]
  status campaign_status [not null, default: 'draft']
  starts_at timestamptz
  ends_at timestamptz
  owner_id bigint [ref: > staff_users.id]
  created_at timestamptz [not null, default: `now()`]

  Indexes {
    status
    owner_id
  }
}

Table customer_campaign_events {
  id bigint [pk, increment]
  customer_id bigint [not null, ref: > customers.id]
  campaign_id bigint [not null, ref: > campaigns.id]
  event_type campaign_event_type [not null]
  payload_json jsonb
  created_at timestamptz [not null, default: `now()`]

  Indexes {
    customer_id
    campaign_id
    event_type
  }
}

Table insights {
  id bigint [pk, increment]
  entity_type activity_entity_type [not null]
  entity_id bigint [not null]
  type insight_type [not null]
  title varchar(255) [not null]
  description text
  severity severity_level [not null, default: 'medium']
  status insight_status [not null, default: 'open']
  created_at timestamptz [not null, default: `now()`]

  Indexes {
    entity_type
    entity_id
    status
    severity
  }
}

Table actions {
  id bigint [pk, increment]
  entity_type activity_entity_type [not null]
  entity_id bigint [not null]
  type action_type [not null]
  status action_status [not null, default: 'pending']
  payload_json jsonb
  created_at timestamptz [not null, default: `now()`]

  Indexes {
    entity_type
    entity_id
    status
  }
}

Table activity_logs {
  id bigint [pk, increment]
  entity_type activity_entity_type [not null]
  entity_id bigint [not null]
  action activity_action_type [not null]
  user_id bigint [ref: > staff_users.id]
  timestamp timestamptz [not null, default: `now()`]

  Indexes {
    (entity_type, entity_id)
    user_id
    timestamp
  }
}
