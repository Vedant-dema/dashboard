# Copy this file to .env.local for local development.
# For cloud deployments set these as build-time environment variables
# in your hosting platform (Render, Railway, Netlify, Vercel, …).
#
# IMPORTANT: Vite bakes VITE_* variables into the bundle at BUILD TIME.
# Changing them after the build has no effect — you must rebuild.

# URL of the Python backend (no trailing slash).
# Local dev: leave empty — the Vite dev-server proxy forwards /api/* to localhost:8000.
# Production: set to the full backend URL, e.g. https://dema-backend.onrender.com
VITE_API_BASE_URL=
