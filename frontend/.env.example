# Copy this file to .env.local for local development.
# For cloud deployments set these as build-time environment variables
# in your hosting platform (Render, Railway, Netlify, Vercel, …).
#
# IMPORTANT: Vite bakes VITE_* variables into the bundle at BUILD TIME.
# Changing them after the build has no effect — you must rebuild.

# URL of the Python backend (no trailing slash).
# Local dev: leave empty — the Vite dev-server proxy forwards /api/* to the Python API.
# Production: set to the full backend URL, e.g. https://dema-backend.onrender.com
# Address autocomplete uses GET /api/v1/geocode/search on the backend (OSM, Mapbox, or Google — see backend/.env.example).
VITE_API_BASE_URL=

# Dev only: where Vite proxies /api (default http://127.0.0.1:8000).
# If Windows reports WinError 10013 on port 8000, pick another port and match it here, e.g.:
# VITE_DEV_PROXY_API=http://127.0.0.1:8765
# Then run: uvicorn main:app --reload --host 127.0.0.1 --port 8765
VITE_DEV_PROXY_API=
