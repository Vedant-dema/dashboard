# Copy this file to .env.local for local development.
# For cloud deployments set these as build-time environment variables
# in your hosting platform (Render, Railway, Netlify, Vercel, etc.).
#
# IMPORTANT: Vite bakes VITE_* variables into the bundle at BUILD TIME.
# Changing them after the build has no effect. Rebuild and redeploy.

# URL of the Python backend (no trailing slash).
# Local dev: leave empty, Vite dev-server proxy forwards /api/* to the Python API.
# Production: set full backend URL, e.g. https://dema-backend.onrender.com
VITE_API_BASE_URL=

# Customer data source mode.
# api   : use backend API
# local : browser-only local storage fallback
# VITE_CUSTOMERS_SOURCE=api

# Optional demo key header for protected demo endpoints.
# VITE_DEMO_API_KEY=

# Dev only: where Vite proxies /api (default http://127.0.0.1:8000).
# MUST match the port you pass to uvicorn (e.g. --port 8010 → set this to that origin).
# If Windows reports WinError 10013 on port 8000, pick another port and match it here.
# VITE_DEV_PROXY_API=http://127.0.0.1:8010

# When true, secondary dashboard languages load machine translations from
# POST /api/v1/ui-translate/batch (requires backend translation keys).
# VITE_ENABLE_LIVE_UI_TRANSLATION=true
